# ============================================
# NoPhish - Comprehensive .gitignore
# ============================================

# --------------------------------------------
# Secrets & Environment Files
# --------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
ssl/
*.log
credentials.json
serviceAccountKey.json

# --------------------------------------------
# Python
# --------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.venv
venv/
ENV/
env/
.venv
pip-log.txt

# --------------------------------------------
# Node.js / Frontend
# --------------------------------------------
frontend/node_modules/
frontend/build/
frontend/.cache/
frontend/dist/
frontend/coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.DS_Store
*.local

# --------------------------------------------
# Docker
# --------------------------------------------
.docker/
docker-compose.override.yml
*.tar
*.tar.gz

# --------------------------------------------
# Database
# --------------------------------------------
*.db
*.sqlite
*.sqlite3
database/*.db
database/*.sqlite

# --------------------------------------------
# IDE & Editors
# --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath
*.sublime-*

# --------------------------------------------
# OS
# --------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --------------------------------------------
# Logs
# --------------------------------------------
logs/
*.log
logs/**/*.log
output/
*.tmp

# --------------------------------------------
# Certificates (Let's Encrypt)
# --------------------------------------------
certbot-www/
ssl/
/etc/letsencrypt/
/var/lib/letsencrypt/

# --------------------------------------------
# Backup Files
# --------------------------------------------
backups/
*.bak
*.backup
*.old
*_backup*

# --------------------------------------------
# Test & Coverage
# --------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage/
*.cover

# --------------------------------------------
# NoPhish Specific
# --------------------------------------------
panel/__pycache__/
panel/*.pyc
vnc/__pycache__/
*.pid

# --------------------------------------------
# Docker Volumes (don't track data)
# --------------------------------------------
postgres_data/
redis_data/
mysql_data/
mongo_data/

# --------------------------------------------
# Certbot Challenge
# --------------------------------------------
.acme.sh/
